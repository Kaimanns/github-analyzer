generator client {
  provider   = "prisma-client-js"

}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- KİMLİK DOĞRULAMA (NextAuth Standart Modelleri) ---
// Bu modeller GitHub ile giriş yaptığında otomatik dolar.

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubUsername String?  // Kullanıcının kendi GitHub adı
  createdAt     DateTime  @default(now())

  // İlişkiler
  accounts      Account[]
  sessions      Session[]
  analyses      Analysis[] // Kullanıcının yaptığı tüm analizler
  favorites     Favorite[] // Kaydettiği profiller
}

// --- ANALİZ VE VERİ MOTORU ---

model Analysis {
  id                String   @id @default(cuid())
  username          String   // Analiz edilen GitHub adı
  
  // Profil Özeti (Dashboard'da tekrar API'ye gitmemek için cache)
  avatarUrl         String?
  bio               String?
  location          String?
  publicRepos       Int
  followers         Int
  following         Int
  totalStars        Int      @default(0)
  totalForks        Int      @default(0)
  accountAgeDays    Int      @default(0)
  
  // Analiz Verisi
  languageData      Json     // LanguageStat[] dizisi
  topRepos          Json     // TopRepo[] dizisi
  analyzedAt        DateTime @default(now())

  // Sınıflandırma
  category              String?  // "Frontend" | "Backend" | "Full-Stack" | "DevOps" | "Data Science"
  classificationReason  String?  @db.Text
  activityScore         Int      @default(0)
  popularityScore       Int      @default(0)
  diversityScore        Int      @default(0)
  overallScore          Int      @default(0)

  // İlişki
  userId            String?  // Analizi yapan kullanıcı (misafir ise null olur)
  user              User?    @relation(fields: [userId], references: [id])

  @@index([username])
  @@unique([username], name: "username_unique")
}


model Favorite {
  id          String   @id @default(cuid())
  targetUser  String   // Favoriye eklenen hesap
  targetAvatar String?
  note        String?  // Kullanıcının bu profil hakkında aldığı not (Örn: "İyi React biliyor")
  addedAt     DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUser]) // Aynı kullanıcı aynı hesabı iki kez favorileyemez
}